# --- TASK 2: NLP Pipeline & POS Tagging ---
# Purpose: Extract adjectives and nouns to map De Barnier's luxury dimensions.

import spacy
nlp = spacy.load('en_core_web_sm')

def extract_semantic_features(text):
    """
    Lemmatizes text and extracts specific POS tags (ADJ, NOUN) 
    relevant to luxury hospitality speech codes.
    """
    doc = nlp(text.lower())
    # Filtering tokens: keeping only alphabetic and relevant POS
    tokens = [token.lemma_ for token in doc if token.is_alpha and not token.is_stop]
    return tokens

