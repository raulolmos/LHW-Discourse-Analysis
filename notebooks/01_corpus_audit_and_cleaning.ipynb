# --- TASK 1: Quality Assurance & Text Scrubbing ---
# Purpose: Clean the LHW institutional corpus for linguistic analysis.

import os
import pandas as pd
import re

def clean_luxury_discourse(text):
    """
    Removes web-interface noise (e.g., 'check availability', 'skip to content')
    and standardizes the text for the LHSC instrument.
    """
    # Remove UI artifacts found in initial audit
    noise_patterns = [
        r'skip to (primary )?content', r'check availability',
        r'local time .*? weather', r'free wifi', r'pet friendly'
    ]
    for pattern in noise_patterns:
        text = re.sub(pattern, '', text, flags=re.IGNORECASE)
    
    # Normalize whitespace and special characters
    text = re.sub(r'\s+', ' ', text).strip()
    return text

